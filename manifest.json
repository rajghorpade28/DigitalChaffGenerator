{
  "manifest_version": 3,
  "name": "Digital Chaff Generator",
  "version": "1.0",
  "description": "Advanced privacy protection via realistic browsing noise and behavioral obfuscation.",
  "permissions": ["tabs", "scripting", "idle", "storage", "cookies", "alarms"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html"
  }
}